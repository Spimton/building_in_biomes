{
    "format_version": "1.10.0",
    "minecraft:attachable": {
        "description": {
            //Replace <identifier> with the full identifier of your item
            "identifier": "spimton:steel_spear",
            "materials": {
                "default": "entity_alphatest",
                "enchanted": "entity_alphatest_glint"
            },
            "textures": {
                //Replace <path> with the filepath to your items texture. It should match up with the filepath given in item_texture.json
                "default": "textures/entity/spear/steel_spear",
                "enchanted": "textures/misc/enchanted_item_glint"
            },
            "geometry": {
                "default": "geometry.spear"
            },
            "animations": {
                "third_person_hold": "animation.spear.held_third_person",
                "first_person_hold": "animation.spear.held_first_person"
            },
            "scripts": {
                "animate": [
                    {
                        "first_person_hold": "c.is_first_person"
                    },
                    {
                        "third_person_hold": "!c.is_first_person"
                    }
                ]
            },
            "render_controllers": [
                "controller.render.item_default"
            ]
        }
    }
}