{
	"format_version": "1.10.0",
	"minecraft:client_entity": {
		"description": {
			"identifier": "spimton:yellow_jester",
			"min_engine_version": "1.10.0",
			"materials": {
				"default": "skeleton",
				"piper_buff": "entity_alphatest"
			},
			"textures": {
				"default": "textures/entity/yellow_jester",
				"piper_buff": "textures/entity/piper_buff/piper_buff_jester"
			},
			"geometry": {
				"default": "geometry.mann"
			},
			"spawn_egg": {
				"texture": "yellow_jester_egg"
			},
			"scripts": {
				"pre_animation": [
					"variable.tcos0 = (Math.cos(query.modified_distance_moved * 38.17) * query.modified_move_speed / variable.gliding_speed_value) * 57.3;"
				],
				"animate": [
					"move.controller",
					"attack.controller",
					"look_at_target.controller",
					"humanoid_base_pose.controller",
					"riding.controller",
					{
						"revolve": "query.is_jump_goal_jumping"
					}
				]
			},
			"animations": {
				"revolve": "animation.mann.revolve",
				"humanoid_base_pose": "animation.humanoid.base_pose",
				"look_at_target_default": "animation.humanoid.look_at_target.default",
				"move": "animation.humanoid.move",
				"sneaking": "animation.humanoid.sneaking",
				"attack": "animation.mann.attack",
				//Controllers
				"humanoid_base_pose.controller": "controller.animation.humanoid.base_pose",
				"look_at_target.controller": "controller.animation.humanoid.look_at_target",
				"move.controller": "controller.animation.villager.move",
				"riding.controller": "controller.animation.humanoid.riding",
				"attack.controller": "controller.animation.skirmisher.attack"
			},
			"render_controllers": [
				"controller.render.piper_buff"
			],
			"enable_attachables": true
		}
	}
}