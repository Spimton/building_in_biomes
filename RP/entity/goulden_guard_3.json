{
    "format_version": "1.10.0",
    "minecraft:client_entity": {
        "description": {
            "identifier": "spimton:goulden_guard_3",
            "materials": {
                "default": "entity_alphatest"
            },
            "textures": {
                "default": "textures/entity/goulden_guard_3"
            },
            "geometry": {
                "default": "geometry.goulden_guard_3"
            },
            "animations": {
                "walk": "animation.goulden_guard_3.walk",
                "look_at_target": "animation.common.look_at_target",
                "move_controller": "controller.animation.iron_golem.move",
                "smash": "animation.goulden_guard_3.smash",
                "jump": "animation.goulden_guard_3.jump",
                "shoot": "animation.goulden_guard_3.shoot"
            },
            "render_controllers": [
                "controller.render.iron_golem"
            ],
            "scripts": {
                "pre_animation": [
                    "variable.modified_tcos0 = Math.clamp(((Math.cos(query.modified_distance_moved * 13.5) * Math.min(query.modified_move_speed, 0.6) / variable.gliding_speed_value) * 25.0), -12.5, 12.5);"
                ],
                "animate": [
                    {
                        "walk": "query.is_moving"
                    },
                    {
                        "jump": "query.is_jump_goal_jumping"
                    },
                    {
                        "shoot": "query.mark_variant == 1"
                    },
                    "look_at_target",
                    "move_controller"
                ]
            },
            "spawn_egg": {
                "texture": "goulden_guard_egg"
            }
        }
    }
}