{
	"format_version": "1.8.0",
	"render_controllers": {
		"controller.render.hampter": {
			"geometry": "geometry.default",
			"materials": [
				{
					"*": "variable.is_enchanted?material.enchanted:material.default"
				}
			],
			"textures": [
				"texture.default",
				"texture.enchanted"
			]
		},
		"controller.render.grand_flame_entity": {
			"uv_anim": {
				"offset": [
					0,
					"math.mod(math.floor(q.life_time * 12.25), 8) / 8"
				],
				"scale": [
					1,
					"1 / 8"
				]
			}
		}
	}
}