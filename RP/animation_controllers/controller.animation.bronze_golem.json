{
    "format_version": "1.10.0",
    "animation_controllers": {
        "controller.animation.bronze_golem.general": {
            "initial_state": "general",
            "states": {
                "general": {
                    "transitions": [
                        {
                            "sitmode": "query.mark_variant == 1"
                        }
                    ],
                    "blend_transition": 0.2
                },
                "sitmode": {
                    "animations": [
                        "sit"
                    ],
                    "transitions": [
                        {
                            "general": "query.mark_variant == 0"
                        }
                    ],
                    "blend_transition": 0.2
                }
            }
        }
    }
}