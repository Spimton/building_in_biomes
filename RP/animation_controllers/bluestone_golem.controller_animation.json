{
    "format_version": "1.10.0",
    "animation_controllers": {
        "controller.animation.bluestone_golem.general": {
            "initial_state": "default",
            "states": {
                "default": {
                    "animations": [
                        "general"
                    ],
                    "transitions": [
                        {
                            "walking": "query.ground_speed>=1"
                        }
                    ],
                    "blend_transition": 0.1
                },
                "walking": {
                    "animations": [
                        "walking"
                    ],
                    "transitions": [
                        {
                            "default": "query.ground_speed<=1"
                        }
                    ],
                    "blend_transition": 0.1
                }
            }
        },
        "controller.animation.bluestone_golem.attack": {
            "initial_state": "default",
            "states": {
                "default": {
                    "transitions": [
                        {
                            "attack": "variable.attack_time>0"
                        }
                    ],
                    "blend_transition": 0.1
                },
                "attack": {
                    "animations": [
                        "attacking"
                    ],
                    "transitions": [
                        {
                            "default": "variable.attack_time<=0&&!query.is_delayed_attacking"
                        }
                    ],
                    "blend_transition": 0.2
                }
            }
        }
    }
}