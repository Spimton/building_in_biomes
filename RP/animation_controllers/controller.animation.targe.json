{
    "format_version": "1.10.0",
    "animation_controllers": {
        "controller.animation.targe.wield_fp": {
            "initial_state": "default",
            "states": {
                "default": {
                    "animations": [
                        {
                            "wield_main_hand_first_person": "c.item_slot == 'main_hand'"
                        },
                        {
                            "wield_off_hand_first_person": "c.item_slot != 'main_hand'"
                        }
                    ],
                    "transitions": [
                        {
                            "blocking": "query.blocking && ((variable.is_blocking_main_hand && c.item_slot == 'main_hand') || (variable.is_blocking_off_hand && c.item_slot == 'off_hand'))"
                        }
                    ]
                },
                "blocking": {
                    "animations": [
                        {
                            "wield_main_hand_first_person": "!variable.is_blocking_main_hand && c.item_slot == 'main_hand'"
                        },
                        {
                            "wield_main_hand_first_person_block": "variable.is_blocking_main_hand && c.item_slot == 'main_hand'"
                        },
                        {
                            "wield_off_hand_first_person_block": "variable.is_blocking_off_hand && c.item_slot == 'off_hand'"
                        }
                    ],
                    "transitions": [
                        {
                            "default": "!query.blocking || q.cooldown_time_remaining > 0"
                        }
                    ]
                }
            }
        },
        "controller.animation.targe.wield_tp": {
            "initial_state": "default",
            "states": {
                "default": {
                    "animations": [
                        {
                            "wield_main_hand_third_person": "c.item_slot == 'main_hand'"
                        },
                        {
                            "wield_off_hand_third_person": "c.item_slot != 'main_hand'"
                        }
                    ],
                    "transitions": [
                        {
                            "blocking": "query.blocking && ((variable.is_blocking_main_hand && c.item_slot == 'main_hand') || (variable.is_blocking_off_hand && c.item_slot == 'off_hand'))"
                        }
                    ]
                },
                "blocking": {
                    "animations": [
                        {
                            "wield_main_hand_third_person": "!variable.is_blocking_main_hand && c.item_slot == 'main_hand'"
                        },
                        {
                            "wield_main_hand_third_person_block": "variable.is_blocking_main_hand && c.item_slot == 'main_hand'"
                        },
                        {
                            "wield_off_hand_third_person_block": "variable.is_blocking_off_hand && c.item_slot == 'off_hand'"
                        }
                    ],
                    "transitions": [
                        {
                            "default": "!query.blocking || q.cooldown_time_remaining > 0"
                        }
                    ]
                }
            }
        }
    }
}