{
	"format_version": "1.10.0",
	"animation_controllers": {
		"controller.animation.skirmisher.attack_del": {
			"initial_state": "default",
			"states": {
				"attack": {
					"animations": [
						"attack"
					],
					"transitions": [
						{
							"default": "query.is_delayed_attacking == 0"
						}
					],
					"blend_transition": 1
				},
				"default": {
					"transitions": [
						{
							"attack": "query.is_delayed_attacking"
						}
					]
				}
			}
		},
		"controller.animation.skirmisher.attack": {
			"states": {
				"attack": {
					"animations": [
						{
							"attack": "variable.attack_time>0"
						}
					],
					"blend_transition": 1
				}
			}
		},
		"controller.animation.coldager.general": {
			"initial_state": "general",
			"states": {
				"general": {
					"animations": [
						"general"
					],
					"transitions": [
						{
							"move": "query.ground_speed>=1"
						},
						{
							"shoot": "query.is_sheared"
						}
					],
					"blend_transition": 0.2
				},
				"shoot": {
					"animations": [
						"shoot"
					],
					"transitions": [
						{
							"general": "!query.is_sheared"
						}
					],
					"blend_transition": 0.1
				},
				"move": {
					"animations": [
						"move"
					],
					"transitions": [
						{
							"general": "query.ground_speed<=1"
						}
					],
					"blend_transition": 0.2
				}
			}
		},
		"controller.animation.satellite.target": {
			"initial_state": "not",
			"states": {
				"not": {
					"animations": [
						"calm"
					],
					"transitions": [
						{
							"yet": "query.has_target"
						}
					]
				},
				"attacking": {
					"transitions": [
						{
							"not": "!query.has_target"
						},
						{
							"yet": "query.has_target && variable.attack_time == 0"
						}
					]
				},
				"yet": {
					"animations": [
						"targeting"
					],
					"transitions": [
						{
							"not": "!query.has_target"
						},
						{
							"attacking": "variable.attack_time >0"
						}
					]
				}
			}
		}
	}
}