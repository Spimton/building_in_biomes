{
	"format_version": "1.10.0",
	"animation_controllers": {
		"controller.animation.iceologer.general": {
			"states": {
				"default": {
					"animations": [
						"default"
					],
					"transitions": [
						{
							"cast": "query.is_casting"
						},
						{
							"throw": "query.is_charged"
						}
					],
					"blend_transition": 0.1
				},
				"throw": {
					"animations": [
						"throw"
					],
					"transitions": [
						{
							"default": "query.all_animations_finished"
						}
					],
					"blend_transition": 0.1
				},
				"cast": {
					"animations": [
						"casting"
					],
					"particle_effects": [
						{
							"effect": "spell",
							"locator": "left_hand"
						},
						{
							"effect": "spell",
							"locator": "right_hand"
						}
					],
					"transitions": [
						{
							"default": "!query.is_casting"
						}
					],
					"blend_transition": 0.1
				}
			}
		},
		"controller.animation.juandice.general": {
			"states": {
				"default": {
					"animations": [],
					"transitions": [
						{
							"shoota": "query.mark_variant == 1"
						},
						{
							"tyre": "query.mark_variant == 2"
						}
					],
					"blend_transition": 0.1
				},
				"shoota": {
					"animations": [
						"shoot"
					],
					"transitions": [
						{
							"default": "query.mark_variant == 0"
						},
						{
							"tyre": "query.mark_variant == 2"
						}
					],
					"blend_transition": 0.1
				},
				"tyre": {
					"animations": [
						"tyre"
					],
					"transitions": [
						{
							"shoota": "query.mark_variant == 1"
						},
						{
							"default": "query.mark_variant == 0"
						}
					],
					"blend_transition": 0.1
				}
			}
		}
	}
}