{
    "format_version": "1.21.130",
    "minecraft:entity": {
        "description": {
            "identifier": "spimton:piglin_pyro",
            "is_spawnable": true,
            "is_summonable": true,
            "runtime_identifier": "zombie_pigman"
        },
        "component_groups": {
            "minecraft:pig_zombie_adult": {
                "minecraft:rideable": {
                    "seat_count": 1,
                    "family_types": [
                        "baby_zombie",
                        "baby_husk"
                    ],
                    "seats": {
                        "position": [
                            0.0,
                            1.175,
                            -0.35
                        ],
                        "lock_rider_rotation": 0
                    }
                },
                "minecraft:behavior.nearest_attackable_target": {
                    "priority": 5,
                    "entity_types": [
                        {
                            "filters": {
                                "any_of": [
                                    {
                                        "test": "is_family",
                                        "subject": "other",
                                        "value": "player"
                                    },
                                    {
                                        "test": "is_family",
                                        "subject": "other",
                                        "value": "snowgolem"
                                    },
                                    {
                                        "test": "is_family",
                                        "subject": "other",
                                        "value": "irongolem"
                                    },
                                    {
                                        "test": "is_family",
                                        "subject": "other",
                                        "value": "wandering_trader"
                                    },
                                    {
                                        "test": "is_family",
                                        "subject": "other",
                                        "value": "morellager:chillager"
                                    },
                                    {
                                        "test": "is_family",
                                        "subject": "other",
                                        "value": "squid"
                                    },
                                    {
                                        "test": "is_family",
                                        "subject": "other",
                                        "value": "bronze_golem"
                                    },
                                    {
                                        "test": "is_family",
                                        "subject": "other",
                                        "value": "villager"
                                    }
                                ]
                            },
                            "max_dist": 20
                        },
                        {
                            "filters": {
                                "all_of": [
                                    {
                                        "test": "is_family",
                                        "subject": "other",
                                        "value": "villager"
                                    },
                                    {
                                        "test": "has_component",
                                        "subject": "other",
                                        "operator": "!=",
                                        "value": "minecraft:is_baby"
                                    }
                                ]
                            },
                            "max_dist": 20
                        }
                    ],
                    "must_see": true
                },
                "minecraft:experience_reward": {
                    "on_death": "query.last_hit_by_player ? 5 + (query.equipment_count * Math.Random(1,3)) : 0"
                }
            },
            "minecraft:pig_zombie_angry": {
                "minecraft:angry": {
                    "duration": 1997,
                    "broadcast_anger": true,
                    "broadcast_range": 20,
                    "broadcast_anger_when_dying": false,
                    "calm_event": {
                        "event": "minecraft:on_calm",
                        "target": "self"
                    }
                }
            },
            "minecraft:pig_zombie_calm": {
                "minecraft:on_target_acquired": {
                    "event": "minecraft:become_angry",
                    "target": "self"
                }
            },
            "spimton:attacker": {
                "minecraft:behavior.ranged_attack": {
                    "attack_radius_min": 1,
                    "attack_interval": 0.01,
                    "attack_radius": 10,
                    "burst_interval": 0.005,
                    "burst_shots": 30,
                    "priority": 1,
                    "ranged_fov": 360,
                    "charge_charged_trigger": 0.1,
                    "charge_shoot_trigger": 0.1
                },
                "minecraft:timer": {
                    "looping": false,
                    "time": 6,
                    "time_down_event": {
                        "event": "spimton:nof",
                        "target": "self"
                    }
                }
            },
            "spimton:nofuel": {
                "minecraft:behavior.avoid_mob_type": {
                    "priority": 1,
                    "max_dist": 6,
                    "max_flee": 10,
                    "sprint_distance": 7,
                    "sprint_speed_multiplier": 2,
                    "walk_speed_multiplier": 2,
                    "entity_types": {
                        "must_see": true,
                        "filters": {
                            "test": "is_target",
                            "subject": "other",
                            "value": true
                        },
                        "max_dist": 6
                    }
                },
                "minecraft:timer": {
                    "looping": false,
                    "time": 6,
                    "time_down_event": {
                        "event": "spimton:yef",
                        "target": "self"
                    }
                }
            }
        },
        "components": {
            "minecraft:is_hidden_when_invisible": {},
            "minecraft:breathable": {
                "total_supply": 15,
                "suffocate_time": 0,
                "breathes_water": true
            },
            "minecraft:on_target_escape": {
                "event": "spimton:rem",
                "target": "self"
            },
            "minecraft:target_nearby_sensor": {
                "inside_range": 7,
                "on_inside_range": {
                    "event": "spimton:adda"
                },
                "on_outside_range": {
                    "event": "spimton:rem"
                },
                "outside_range": 8
            },
            "minecraft:behavior.melee_box_attack": {
                "priority": 9,
                "speed_multiplier": 1.5
            },
            "minecraft:equip_item": {},
            "minecraft:collision_box": {
                "width": 0.6,
                "height": 1.9
            },
            "minecraft:nameable": {},
            "minecraft:navigation.walk": {
                "is_amphibious": true,
                "can_pass_doors": true,
                "can_open_doors": true,
                "avoid_water": true,
                "avoid_portals": true,
                "can_path_over_lava": true
            },
            "minecraft:movement.basic": {},
            "minecraft:jump.static": {},
            "minecraft:can_climb": {},
            "minecraft:fire_immune": {},
            "minecraft:type_family": {
                "family": [
                    "zombie_pigman",
                    "undead",
                    "monster",
                    "mob"
                ]
            },
            "minecraft:loot": {
                "table": "loot_tables/entities/zombie_pigman.json"
            },
            "minecraft:health": {
                "value": 20,
                "max": 20
            },
            "minecraft:movement": {
                "value": 0.13
            },
            "minecraft:attack": {
                "damage": 5
            },
            "minecraft:despawn": {
                "despawn_from_distance": {}
            },
            "minecraft:behavior.hurt_by_target": {
                "priority": 1
            },
            "minecraft:shooter": {
                "power": 0,
                "def": "spimton:pyroglin_proj"
            },
            "minecraft:behavior.mount_pathing": {
                "priority": 2,
                "speed_multiplier": 1.25,
                "target_dist": 0,
                "track_target": true
            },
            "minecraft:behavior.stomp_turtle_egg": {
                "priority": 6,
                "speed_multiplier": 1,
                "search_range": 10,
                "search_height": 2,
                "goal_radius": 1.14,
                "interval": 20
            },
            "minecraft:behavior.random_stroll": {
                "priority": 8,
                "speed_multiplier": 1.0
            },
            "minecraft:behavior.look_at_player": {
                "priority": 9,
                "look_distance": 6.0,
                "probability": 0.02
            },
            "minecraft:behavior.random_look_around": {
                "priority": 10
            },
            "minecraft:physics": {},
            "minecraft:pushable": {
                "is_pushable": true,
                "is_pushable_by_piston": true
            },
            "minecraft:conditional_bandwidth_optimization": {}
        },
        "events": {
            "spimton:rem": {
                "remove": {
                    "component_groups": [
                        "spimton:attacker"
                    ]
                }
            },
            "spimton:adda": {
                "sequence": [
                    {
                        "filters": {
                            "test": "has_component",
                            "subject": "self",
                            "value": "minecraft:behavior.avoid_mob_type",
                            "operator": "!="
                        },
                        "add": {
                            "component_groups": [
                                "spimton:attacker"
                            ]
                        }
                    }
                ]
            },
            "spimton:nof": {
                "remove": {
                    "component_groups": [
                        "spimton:attacker"
                    ]
                },
                "queue_command": {
                    "target": "self",
                    "command": [
                        "playanimation @s animation.piglin_pyro.nofuel"
                    ]
                },
                "add": {
                    "component_groups": [
                        "spimton:nofuel"
                    ]
                }
            },
            "spimton:yef": {
                "remove": {
                    "component_groups": [
                        "spimton:nofuel"
                    ]
                },
                "add": {
                    "component_groups": [
                        "spimton:attacker"
                    ]
                }
            },
            "minecraft:entity_transformed": {
                "sequence": [
                    // Transform baby pig to baby zombie pigman
                    // Transform adult pig to adult zombie pigman
                    {
                        "filters": {
                            "test": "has_component",
                            "subject": "other",
                            "operator": "!=",
                            "value": "minecraft:is_baby"
                        },
                        "trigger": "spawn_adult"
                    }
                ]
            },
            "minecraft:entity_spawned": {
                "randomize": [
                    {
                        "weight": 95,
                        "trigger": "spawn_adult"
                    }
                ]
            },
            "spawn_adult": {
                "add": {
                    "component_groups": [
                        "minecraft:pig_zombie_adult",
                        "minecraft:pig_zombie_angry"
                    ]
                }
            },
            "minecraft:on_calm": {
                "remove": {
                    "component_groups": [
                        "minecraft:pig_zombie_angry"
                    ]
                },
                "add": {
                    "component_groups": [
                        "minecraft:pig_zombie_calm"
                    ]
                }
            },
            "minecraft:become_angry": {
                "remove": {
                    "component_groups": [
                        "minecraft:pig_zombie_calm"
                    ]
                },
                "add": {
                    "component_groups": [
                        "minecraft:pig_zombie_angry"
                    ]
                }
            }
        }
    }
}