{
	"format_version": "1.16.0",
	"minecraft:entity": {
		"description": {
			"identifier": "spimton:sudden_cardiac_arrest_biggu",
			"is_summonable": true,
			"is_experimental": false
		},
		"component_groups": {
			"minecraft:exploding": {
				"minecraft:explode": {
					"fuse_length": 0.1,
					"fuse_lit": true,
					"power": 3.5,
					"causes_fire": false,
					"breaks_blocks": true,
					"destroy_affected_by_griefing": true
				}
			}
		},
		"components": {
			"minecraft:timer": {
				"looping": false,
				"time": 15,
				"time_down_event": {
					"event": "minecraft:start_exploding",
					"target": "self"
				}
			},
			"minecraft:experience_reward": {
				"on_death": "query.last_hit_by_player?5:0"
			},
			"minecraft:type_family": {
				"family": [
					"creeper",
					"monster",
					"mob",
					"spimton:weeper"
				]
			},
			"minecraft:follow_range": {
				"value": 32
			},
			"minecraft:breathable": {
				"total_supply": 15,
				"suffocate_time": 0
			},
			"minecraft:knockback_resistance": {
				"value": 1
			},
			"minecraft:nameable": {},
			"minecraft:collision_box": {
				"width": 1.225,
				"height": 1.225
			},
			"minecraft:movement": {
				"value": 0.25
			},
			"minecraft:damage_sensor": {
				"triggers": [
					{
						"cause": "all",
						"damage_multiplier": 0.01
					}
				]
			},
			"minecraft:navigation.walk": {
				"can_path_over_water": true
			},
			"minecraft:movement.basic": {
				"max_turn": 45
			},
			"minecraft:jump.static": {},
			"minecraft:can_climb": {},
			"minecraft:loot": {
				"table": "loot_tables/entities/creeper.json"
			},
			"minecraft:health": {
				"value": 300,
				"max": 300
			},
			"minecraft:hurt_on_condition": {
				"damage_conditions": [
					{
						"filters": {
							"test": "in_lava",
							"subject": "self",
							"operator": "==",
							"value": true
						},
						"cause": "lava",
						"damage_per_tick": 4
					}
				]
			},
			"minecraft:attack": {
				"damage": 4
			},
			"minecraft:behavior.melee_attack": {
				"attack_once": false,
				"priority": 1,
				"max_path_time": 1,
				"min_path_time": 0.67,
				"melee_fov": 335,
				"speed_multiplier": 1.5,
				"on_attack": {
					"event": "minecraft:start_exploding",
					"target": "self"
				},
				"track_target": true,
				"reach_multiplier": 1
			},
			"minecraft:despawn": {
				"despawn_from_distance": {}
			},
			"minecraft:behavior.float": {
				"priority": 0
			},
			"minecraft:behavior.random_stroll": {
				"priority": 5,
				"speed_multiplier": 1
			},
			"minecraft:behavior.look_at_player": {
				"priority": 6,
				"look_distance": 8
			},
			"minecraft:behavior.random_look_around": {
				"priority": 6
			},
			"minecraft:behavior.nearest_attackable_target": {
				"priority": 1,
				"must_see": true,
				"must_see_forget_duration": 3,
				"entity_types": [
					{
						"filters": {
							"all_of": [
								{
									"test": "is_family",
									"subject": "other",
									"operator": "!=",
									"value": "creeper"
								},
								{
									"test": "is_family",
									"subject": "other",
									"operator": "!=",
									"value": "spimton:weeper"
								},
								{
									"test": "is_family",
									"subject": "other",
									"operator": "!=",
									"value": "inanimate"
								}
							]
						},
						"max_dist": 32
					}
				]
			},
			"minecraft:behavior.hurt_by_target": {
				"priority": 2
			},
			"minecraft:physics": {},
			"minecraft:pushable": {
				"is_pushable": true,
				"is_pushable_by_piston": true
			},
			"minecraft:on_target_escape": {
				"event": "minecraft:stop_exploding",
				"target": "self"
			},
			"minecraft:conditional_bandwidth_optimization": {}
		},
		"events": {
			"minecraft:start_exploding": {
				"sequence": [
					{
						"filters": {
							"test": "has_component",
							"operator": "!=",
							"value": "minecraft:is_charged"
						},
						"add": {
							"component_groups": [
								"minecraft:exploding"
							]
						}
					}
				]
			},
			"minecraft:stop_exploding": {
				"remove": {
					"component_groups": [
						"minecraft:exploding"
					]
				}
			}
		}
	}
}