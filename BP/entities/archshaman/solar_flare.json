			"minecraft:physics": {}
		},
		"events": {
			"spimton:firee": {
				"queue_command": {
					"command": [
						"fill ~ ~ ~ ~ ~1 ~ fire replace air"
					],
					"target": "self"
				}
			},
			"spimton:kira": {
				"add": {
					"component_groups": [
						"spimton:desp"
					]
				}
			},
			"spimton:heal": {
