						"title @a[r=30] actionbar The Archshaman used up its flames summoned the SUN!",
						"event entity @s spimton:kira"
					],
					"target": "self"
				}
			},
			"spimton:healesser": {
				"queue_command": {
					"command": [
						"effect @e[type=spimton:overgrown_archshaman] instant_damage 1 1 true",
						"title @a[r=30] actionbar The Archshaman used up its flames and healed!",
						"event entity @s spimton:kira"
					],
					"target": "self"
				}
			}
		}
