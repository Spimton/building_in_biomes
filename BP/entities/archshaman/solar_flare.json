			"minecraft:type_family": {
				"family": [
					"spimton:archshaman",
					"inanimate"
				]
			},
			"minecraft:damage_sensor": {
				"triggers": [
					{
						"cause": "fire",
						"deals_damage": "no"
					},
					{
						"cause": "fire_tick",
						"deals_damage": "no"
					},
					{
						"cause": "entity_explosion",
						"deals_damage": "no"
					},
					{
						"cause": "entity_attack",
						"deals_damage": "no"
					},
					{
						"cause": "attack",
						"deals_damage": "no"
					},
					{
						"cause": "projectile",
						"deals_damage": "no"
					},
					{
						"cause": "magic",
						"deals_damage": "no"
					}
				]
			},
			"minecraft:environment_sensor": {
				"triggers": [
					{
						"filters": {
							"test": "in_water_or_rain",
							"subject": "self",
							"value": true
						},
						"target": "self",
						"event": "spimton:kira"
					}
				]
