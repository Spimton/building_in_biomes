{
	"format_version": "1.16.0",
	"minecraft:entity": {
		"description": {
			"identifier": "spimton:sun",
			"spawn_category": "monster",
			"is_spawnable": true,
			"is_summonable": true,
			"is_experimental": false
		},
		"component_groups": {
			"minecraft:start_damage_timer": {
				"minecraft:timer": {
					"looping": false,
					"randomInterval": true,
					"time": 20,
					"time_down_event": {
						"event": "minecraft:add_periodic_damage"
					}
				}
			},
			"minecraft:periodic_damage": {
				"minecraft:explode": {
					"breaks_blocks": true,
					"causes_fire": true,
					"destroy_affected_by_griefing": true,
					"fire_affected_by_griefing": true,
					"power": 5,
					"fuse_lit": true,
					"fuse_length": 0
				}
			}
		},
		"components": {
			"minecraft:damage_sensor": {
				"triggers": [
					{
						"cause": "suffocation",
						"deals_damage": false
					},
					{
						"cause": "entity_explosion",
						"deals_damage": false
					},
					{
						"cause": "override",
						"deals_damage": false
					}
				]
			},
			"minecraft:is_hidden_when_invisible": {},
			"minecraft:experience_reward": {
				"on_death": "query.last_hit_by_player ? 500 + (query.equipment_count * Math.Random(1,3)) : 0"
			},
			"minecraft:nameable": {},
			"minecraft:type_family": {
				"family": [
					"inanimate",
					"spimton:archshaman",
					"monster",
					"mob"
				]
			},
			"minecraft:health": {
				"value": 100,
				"max": 100
			},
			"minecraft:attack": {
				"damage": 3
			},
			"minecraft:collision_box": {
				"width": 2,
				"height": 2
			},
			"minecraft:movement": {
				"value": 0.8
			},
			"minecraft:navigation.walk": {
				"can_path_over_water": true
			},
			"minecraft:movement.basic": {},
			"minecraft:jump.static": {},
			"minecraft:can_climb": {},
			"minecraft:fire_immune": {},
			"minecraft:despawn": {
				"despawn_from_distance": {}
			},
			"minecraft:behavior.float": {
				"priority": 0
			},
			"minecraft:behavior.charge_attack": {
				"priority": 4,
				"success_rate": 1,
				"max_distance": 70,
				"min_distance": 0,
				"speed_multiplier": 1
			},
			"minecraft:area_attack": {
				"damage_range": 0.1,
				"cause": "magic",
				"damage_per_tick": 3,
				"entity_filter": {
					"test": "is_family",
					"value": "spimton:archshaman",
					"operator": "!=",
					"subject": "other"
				}
			},
			"minecraft:behavior.nearest_attackable_target": {
				"priority": 3,
				"entity_types": [
					{
						"filters": {
							"all_of": [
								{
									"test": "is_family",
									"subject": "other",
									"value": "inanimate",
									"operator": "!="
								},
								{
									"test": "is_family",
									"subject": "other",
									"value": "spimton:archshaman",
									"operator": "!="
								}
							]
						},
						"max_dist": 70
					}
				],
				"must_see": true
			},
			"minecraft:on_death": {
				"event": "spimton:damage"
			},
			"minecraft:behavior.look_at_player": {
				"priority": 9,
				"look_distance": 6.0,
				"probability": 0.02
			},
			"minecraft:behavior.look_at_entity": {
				"priority": 9,
				"look_distance": 6.0,
				"probability": 0.02,
				"filters": {
					"test": "is_family",
					"subject": "other",
					"value": "mob"
				}
			},
			"minecraft:behavior.hurt_by_target": {
				"priority": 1
			},
			"minecraft:physics": {
				"has_gravity": false,
				"has_collision": false
			},
			"minecraft:conditional_bandwidth_optimization": {},
			"minecraft:game_event_movement_tracking": {
				"emit_move": false,
				"emit_swim": false
			}
		},
		"events": {
			"spimton:damage": {
				"queue_command": {
					"command": "damage @n[type=spimton:overgrown_archshaman] 50 void",
					"target": "self"
				}
			},
			"minecraft:entity_spawned": {
				"trigger": "minecraft:add_damage_timer"
			},
			"minecraft:add_damage_timer": {
				"add": {
					"component_groups": [
						"minecraft:start_damage_timer"
					]
				}
			},
			"minecraft:add_periodic_damage": {
				"add": {
					"component_groups": [
						"minecraft:periodic_damage"
					]
				},
				"remove": {
					"component_groups": [
						"minecraft:start_damage_timer"
					]
				}
			}
		}
	}
}