                    }
                }
            },
            "spimton:smash": {
                "minecraft:mark_variant": {
                    "value": 0
                },
                "minecraft:timer": {
                    "looping": false,
                    "time": 1,
                    "time_down_event": {
                        "event": "spimton:melee_attack",
