                "height": 5,
                "width": 2
            },
            "minecraft:on_target_escape": {
                "event": "spimton:not_attacking"
            },
            "minecraft:follow_range": {
                "max": 32,
                "value": 40
            },
            "minecraft:target_nearby_sensor": {
                "inside_range": 8,
                "must_see": false,
                "outside_range": 12,
                "on_outside_range": {
                    "event": "spimton:leap"
                },
                "on_inside_range": {
                    "event": "spimton:choose_attack"
                }
            },
            "minecraft:attack": {
                "damage": 0
            },
            "minecraft:physics": {},
            "minecraft:conditional_bandwidth_optimization": {}
        },
        "events": {
            "spimton:melee_attack": {
                "queue_command": {
                    "command": [
                        //"say melee",
                        "damage @e[family=!spimton:archshaman,type=!item,dx=30,dy=5.225, dz=30,x=~-15,y=~-5,z=~-15] 30 entity_attack entity @n[type=spimton:goulden_guard_3]"
                    ]
                }
            },
            "spimton:not_attacking": {
                "add": {
                    "component_groups": [
                        "spimton:not_attacking"
                    ]
                },
                "remove": {
                    "component_groups": [
                        "spimton:far",
                        "spimton:ranged",
                        "spimton:wait_attack",
                        "spimton:smash"
                    ]
                }
            },
            "spimton:leap": {
                "add": {
                    "component_groups": [
                        "spimton:far"
                    ]
                },
                "remove": {
                    "component_groups": [
                        "spimton:not_attacking"
                    ]
                }
            },
            "spimton:choose_attack": {
                "add": {
                    "component_groups": [
                        "spimton:wait_attack"
                    ]
                },
                "remove": {
                    "component_groups": [
                        "spimton:far",
                        "spimton:ranged",
                        "spimton:smash",
                        "spimton:not_attacking"
                    ]
                }
            },
            "spimton:smash_attack": {
                "queue_command": {
                    "command": [
                        // "say smash",
                        "playanimation @s animation.goulden_guard_3.smash none 0",
                        "particle spimton:opulent_smash ~ ~ ~"
                    ],
                    "target": "self"
                },
                "add": {
                    "component_groups": [
                        "spimton:smash"
                    ]
                },
                "remove": {
                    "component_groups": [
                        "spimton:ranged",
                        "spimton:wait_attack"
                    ]
                }
            },
            "spimton:shoot_attack": {
                "add": {
                    "component_groups": [
                        "spimton:ranged"
                    ]
                },
                "remove": {
                    "component_groups": [
                        "spimton:wait_attack",
                        "spimton:smash"
                    ]
                }
            },
            "spimton:attack": {
                "queue_command": {
                    "command": [
                        //"say choose",
                        "execute if entity @n[type=spimton:goulden_guard_3,dx=20,dy=6, dz=20,x=~-10,y=~5,z=~-10] run event entity @n[type=spimton:goulden_guard_3] spimton:smash_attack",
                        "execute unless entity @n[type=spimton:goulden_guard_3,dx=20,dy=6, dz=20,x=~-10,y=~5,z=~-10] run event entity @n[type=spimton:goulden_guard_3] spimton:shoot_attack"
                    ],
                    "target": "target"
                }
            }
        }
    }
}