                "minecraft:behavior.fire_at_target": {
                    "priority": 0,
                    "target_anchor": 0,
                    "projectile_def": "spimton:obliterator_laser",
                    "attack_range": [
                        0,
                        64
                    ],
                    "target_offset": [
                        0,
                        1.225,
                        0
                    ],
