			"minecraft:environment_sensor": {
				"triggers": {
					"filters": {
						"test": "is_underwater"
					},
					"event": "desp"
				}
			},
			"minecraft:collision_box": {
				"height": 0,
				"width": 0
			},
			"minecraft:physics": {}
		},
		"events": {
			"minecraft:entity_spawned": {
				"queue_command": {
					"command": "particle spimton:cloud ~ ~ ~"
				}
			},
			"spimton:effects": {
				"queue_command": {
					"command": [
						"effect @e[r=3] poison 10 0 true",
						"effect @e[r=3] slowness 10 0 true"
					]
				}
			},
			"spimton:kll": {
				"queue_command": {
					"command": [
						"particle spimton:cloud ~ ~1 ~",
						"event entity @s desp"
					]
				}
			},
			"desp": {
				"add": {
					"component_groups": [
						"spimton:despawn"
					]
				}
