{
	"format_version": "1.20.80",
	"minecraft:entity": {
		"description": {
			"identifier": "spimton:pbd",
			"is_spawnable": false,
			"is_summonable": true
		},
		"component_groups": {
			"spimton:despawn": {
				"minecraft:instant_despawn": {}
			}
		},
		"components": {
			"minecraft:health": {
				"value": 30,
				"max": 30
			},
			"minecraft:type_family": {
				"family": [
					"inanimate"
				]
			},
			"minecraft:damage_sensor": {
