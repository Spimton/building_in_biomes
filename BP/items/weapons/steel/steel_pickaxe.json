{
	"format_version": "1.20.80",
	"minecraft:item": {
		"description": {
			"identifier": "spimton:steel_pickaxe",
			"menu_category": {
				"category": "equipment",
				"group": "itemGroup.name.pickaxe"
			}
		},
		"components": {
			"minecraft:max_stack_size": 1,
			"minecraft:hand_equipped": true,
			"minecraft:can_destroy_in_creative": true,
			"minecraft:durability": {
				"max_durability": 1000,
				"damage_chance": {
					"min": 50,
					"max": 100
				}
			},
			"minecraft:icon": "steel_pickaxe",
			"minecraft:damage": 4,
			"minecraft:enchantable": {
				"value": 5,
				"slot": "pickaxe"
			},
			"minecraft:repairable": {
				"repair_items": [
					{
						"items": [
							"spimton:steel_ingot"
						],
						"repair_amount": "query.max_durability*0.1"
					},
					{
						"items": [
							"spimton:steel_pickaxe"
						],
						"repair_amount": "context.other->query.remaining_durability+0.12*context.other->query.max_durability"
					}
				]
			},
			"minecraft:digger": {
				"use_efficiency": true,
				"destroy_speeds": [
					{
						"block": {
							"tags": "query.any_tag('minecraft:is_pickaxe_item_destructible') && !q.all_tags('minecraft:diamond_tier_destructible')"
						},
						"speed": 8
					},
					{
						"block": {
							"tags": "q.any_tag('stone', 'metal')"
						},
						"speed": 7
					},
					{
						"block": {
							"tags": "q.any_tag('stone_pick_diggable','iron_pick_diggable')"
						},
						"speed": 7
					}
				]
			},
			"minecraft:tags": {
				"tags": [
					"minecraft:is_pickaxe",
					"minecraft:is_tool",
					"minecraft:iron_tier",
					"spimton:has_durability"
				]
			}
		}
	}
}