{
	"format_version": "1.21.50",
	"minecraft:item": {
		"description": {
			"identifier": "spimton:steel_shovel",
			"menu_category": {
				"category": "equipment",
				"group": "itemGroup.name.shovel"
			}
		},
		"components": {
			"minecraft:max_stack_size": 1,
			"minecraft:hand_equipped": true,
			"minecraft:can_destroy_in_creative": true,
			"minecraft:durability": {
				"max_durability": 900,
				"damage_chance": {
					"min": 50,
					"max": 100
				}
			},
			"minecraft:icon": "steel_shovel",
			"minecraft:damage": 3,
			"minecraft:enchantable": {
				"value": 5,
				"slot": "shovel"
			},
			"minecraft:repairable": {
				"repair_items": [
					{
						"items": [
							"spimton:steel_ingot"
						],
						"repair_amount": "query.max_durability*0.1"
					},
					{
						"items": [
							"spimton:steel_shovel"
						],
						"repair_amount": "context.other->query.remaining_durability+0.12*context.other->query.max_durability"
					}
				]
			},
			"minecraft:digger": {
				"use_efficiency": true,
				"destroy_speeds": [
					{
						"block": {
							"tags": "query.any_tag('minecraft:is_dirt','minecraft:is_shovel_item_destructible')"
						},
						"speed": 10
					},
					{
						"block": "minecraft:snow",
						"speed": 10
					}
				]
			},
			"minecraft:tags": {
				"tags": [
					"minecraft:is_shovel",
					"minecraft:is_tool",
					"spimton:steel",
					"spimton:has_durability"
				]
			}
		}
	}
}