{
    "format_version": "1.21.50",
    "minecraft:block": {
        "description": {
            "identifier": "spimton:netherrack_pillar",
            "menu_category": {
                "category": "construction"
            },
            "traits": {
                "minecraft:placement_position": {
                    "enabled_states": [
                        "minecraft:block_face"
                    ]
                }
            }
        },
        "components": {
            "tag:stone": {},
            "tag:minecraft:is_pickaxe_item_destructible": {},
            "minecraft:geometry": "minecraft:geometry.full_block",
            "minecraft:material_instances": {
                "*": {
                    "texture": "netherrack_pillar_side",
                    "render_method": "opaque"
                },
                "up": {
                    "texture": "netherrack_pillar_top",
                    "render_method": "opaque"
                },
                "down": {
                    "texture": "netherrack_pillar_top",
                    "render_method": "opaque"
                }
            },
            "minecraft:destructible_by_mining": {
                "seconds_to_destroy": 3.5
            },
            "tag:minecraft:wooden_tier_destructible": {}
        },
        "permutations": [
            {
                "condition": "q.block_state('minecraft:block_face') == 'up' || q.block_state('minecraft:block_face') == 'down'",
                "components": {
                    "minecraft:transformation": {
                        "rotation": [
                            0,
                            0,
                            0
                        ]
                    }
                }
            },
            {
                "condition": "q.block_state('minecraft:block_face') == 'east' || q.block_state('minecraft:block_face') == 'west'",
                "components": {
                    "minecraft:transformation": {
                        "rotation": [
                            0,
                            0,
                            90
                        ]
                    }
                }
            },
            {
                "condition": "q.block_state('minecraft:block_face') == 'north' || q.block_state('minecraft:block_face') == 'south'",
                "components": {
                    "minecraft:transformation": {
                        "rotation": [
                            90,
                            0,
                            0
                        ]
                    }
                }
            }
        ]
    }
}