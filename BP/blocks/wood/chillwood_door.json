{
    "format_version": "1.21.130",
    "minecraft:block": {
        "description": {
            "identifier": "spimton:chillwood_door",
            "menu_category": {
                "category": "construction",
                "is_hidden_in_commands": false
            },
            "traits": {
                "minecraft:placement_direction": {
                    "enabled_states": [
                        "minecraft:cardinal_direction"
                    ]
                }
            },
            "states": {
                "spimton:open_bit": [
                    false,
                    true
                ],
                "spimton:upper_block_bit": [
                    false,
                    true
                ],
                "spimton:door_hinge_bit": [
                    false,
                    true
                ]
            }
        },
        "permutations": [
            {
                "condition": "query.block_state('minecraft:cardinal_direction') == 'north'",
                "components": {
                    "minecraft:transformation": {
                        "rotation": [
                            0,
                            0,
                            0
                        ]
                    }
                }
            },
            {
                "condition": "query.block_state('minecraft:cardinal_direction') == 'south'",
                "components": {
                    "minecraft:transformation": {
                        "rotation": [
                            0,
                            180,
                            0
                        ]
                    }
                }
            },
            {
                "condition": "query.block_state('minecraft:cardinal_direction') == 'east'",
                "components": {
                    "minecraft:transformation": {
                        "rotation": [
                            0,
                            270,
                            0
                        ]
                    }
                }
            },
            {
                "condition": "query.block_state('minecraft:cardinal_direction') == 'west'",
                "components": {
                    "minecraft:transformation": {
                        "rotation": [
                            0,
                            90,
                            0
                        ]
                    }
                }
            },
            {
                "condition": "q.block_state('spimton:open_bit') && !q.block_state('spimton:door_hinge_bit')",
                "components": {
                    "minecraft:collision_box": {
                        "origin": [
                            5,
                            0,
                            -8
                        ],
                        "size": [
                            3,
                            16,
                            16
                        ]
                    },
                    "minecraft:selection_box": {
                        "origin": [
                            5,
                            0,
                            -8
                        ],
                        "size": [
                            3,
                            16,
                            16
                        ]
                    }
                }
            },
            {
                "condition": "q.block_state('spimton:open_bit') && q.block_state('spimton:door_hinge_bit')",
                "components": {
                    "minecraft:collision_box": {
                        "origin": [
                            -8,
                            0,
                            -8
                        ],
                        "size": [
                            3,
                            16,
                            16
                        ]
                    },
                    "minecraft:selection_box": {
                        "origin": [
                            -8,
                            0,
                            -8
                        ],
                        "size": [
                            3,
                            16,
                            16
                        ]
                    }
                }
            },
            {
                "condition": "!q.block_state('spimton:upper_block_bit')",
                "components": {
                    "minecraft:material_instances": {
                        "*": {
                            "texture": "chillwood_door_lower",
                            "render_method": "alpha_test_single_sided"
                        }
                    }
                }
            },
            {
                "condition": "q.block_state('spimton:upper_block_bit')",
                "components": {
                    "minecraft:material_instances": {
                        "*": {
                            "texture": "chillwood_door_upper",
                            "render_method": "alpha_test_single_sided"
                        }
                    }
                }
            }
        ],
        "components": {
            "minecraft:movable": {
                "movement_type": "popped",
                "sticky": "none"
            },
            "minecraft:collision_box": {
                "origin": [
                    -8,
                    0,
                    5
                ],
                "size": [
                    16,
                    16,
                    3
                ]
            },
            "minecraft:selection_box": {
                "origin": [
                    -8,
                    0,
                    5
                ],
                "size": [
                    16,
                    16,
                    3
                ]
            },
            "minecraft:destructible_by_mining": {
                "seconds_to_destroy": 5
            },
            "minecraft:destructible_by_explosion": {
                "explosion_resistance": 6
            },
            "minecraft:material_instances": {
                "minecraft:material_instances": {
                    "*": {
                        "texture": "chillwood_door_lower",
                        "render_method": "alpha_test_single_sided"
                    }
                }
            },
            "minecraft:geometry": {
                "identifier": "geometry.door",
                "bone_visibility": {
                    "door_open": "q.block_state('spimton:open_bit') && !q.block_state('spimton:door_hinge_bit')",
                    "door_closed": "!q.block_state('spimton:open_bit') && !q.block_state('spimton:door_hinge_bit')",
                    "door_open_flipped": "q.block_state('spimton:open_bit') && q.block_state('spimton:door_hinge_bit')",
                    "door_closed_flipped": "!q.block_state('spimton:open_bit') && q.block_state('spimton:door_hinge_bit')"
                }
            },
            "minecraft:redstone_consumer": {
                "min_power": 0,
                "propogates_power": false
            },
            "spimton:doorNeo": {
                "block_state": "spimton:open_bit",
                "door_part": "spimton:upper_block_bit",
                "enable_sound": "open.wooden_door",
                "disable_sound": "close.wooden_door"
            },
            "tag:minecraft:is_axe_item_destructible": {},
            "tag:wood": {},
            "tag:spimton:door": {},
            "tag:spimton:axe": {},
            "tag:spimton:stone_tier_destructible": {}
        }
    }
}