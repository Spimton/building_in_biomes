{
    "format_version": "1.21.130",
    "minecraft:block": {
        "description": {
            "identifier": "spimton:overgrown_dungeon_torch", // Identifier for your torch block
            "menu_category": {
                "category": "items"
            },
            "traits": {
                "minecraft:placement_position": {
                    "enabled_states": [
                        "minecraft:block_face"
                    ]
                }
            },
            "states": {
                "spimton:lit": [
                    true,
                    false
                ]
            }
        },
        "permutations": [
            // Makes the block rotate like torches and modifies the selection boxes
            {
                "condition": "query.block_state('minecraft:block_face') == 'north'",
                "components": {
                    "minecraft:transformation": {
                        "rotation": [
                            0,
                            90,
                            0
                        ]
                    },
                    "minecraft:selection_box": {
                        "origin": [
                            3,
                            3,
                            -2.5
                        ],
                        "size": [
                            5,
                            10,
                            5
                        ]
                    },
                    "minecraft:collision_box": {
                        "origin": [
                            3,
                            3,
                            -2.5
                        ],
                        "size": [
                            5,
                            10,
                            5
                        ]
                    }
                }
            },
            {
                "condition": "query.block_state('minecraft:block_face') == 'south'",
                "components": {
                    "minecraft:transformation": {
                        "rotation": [
                            0,
                            -90,
                            0
                        ]
                    },
                    "minecraft:selection_box": {
                        "origin": [
                            2.5,
                            3,
                            -2.5
                        ],
                        "size": [
                            5.5,
                            10,
                            5
                        ]
                    },
                    "minecraft:collision_box": {
                        "origin": [
                            2.5,
                            3,
                            -2.5
                        ],
                        "size": [
                            5.5,
                            10,
                            5
                        ]
                    }
                }
            },
            {
                "condition": "query.block_state('minecraft:block_face') == 'east'",
                "components": {
                    "minecraft:selection_box": {
                        "origin": [
                            2.5,
                            3,
                            -2.5
                        ],
                        "size": [
                            5.5,
                            10,
                            5
                        ]
                    },
                    "minecraft:collision_box": {
                        "origin": [
                            2.5,
                            3,
                            -2.5
                        ],
                        "size": [
                            5.5,
                            10,
                            5
                        ]
                    }
                }
            },
            {
                "condition": "query.block_state('minecraft:block_face') == 'west'",
                "components": {
                    "minecraft:transformation": {
                        "rotation": [
                            0,
                            180,
                            0
                        ]
                    },
                    "minecraft:selection_box": {
                        "origin": [
                            2.5,
                            3,
                            -2.5
                        ],
                        "size": [
                            5.5,
                            10,
                            5
                        ]
                    },
                    "minecraft:collision_box": {
                        "origin": [
                            2.5,
                            3,
                            -2.5
                        ],
                        "size": [
                            5.5,
                            10,
                            5
                        ]
                    }
                }
            },
            {
                "condition": "query.block_state('spimton:lit') == true",
                "components": {
                    "minecraft:light_emission": 14
                }
            },
            {
                "condition": "query.block_state('spimton:lit') == false",
                "components": {
                    "minecraft:light_emission": 0
                }
            },
            {
                "condition": "query.block_state('minecraft:block_face') == 'up' || query.block_state('minecraft:block_face') == 'down'",
                "components": {
                    "minecraft:geometry": "geometry.dungeon_torch_floor",
                    "minecraft:material_instances": {
                        "*": {
                            "texture": "overgrown_dungeon_torch", // The texture used for the torch
                            "render_method": "alpha_test"
                        }
                    }
                }
            },
            {
                "condition": "query.block_state('minecraft:block_face') == 'west' || query.block_state('minecraft:block_face') == 'east' || query.block_state('minecraft:block_face') == 'north' || query.block_state('minecraft:block_face') == 'south'",
                "components": {
                    "minecraft:geometry": "geometry.dungeon_torch_wall",
                    "minecraft:material_instances": {
                        "*": {
                            "texture": "overgrown_dungeon_torch", // The texture used for the torch
                            "render_method": "alpha_test"
                        }
                    }
                }
            }
        ],
        "components": {
            "minecraft:geometry": "geometry.dungeon_torch_floor",
            "minecraft:selection_box": {
                "origin": [
                    -1.75,
                    0,
                    -1.75
                ],
                "size": [
                    3.5,
                    10,
                    3.5
                ]
            },
            "minecraft:placement_filter": {
                "conditions": [
                    {
                        "allowed_faces": [ // Decides in which faces the torch can be placed
                            "up",
                            "side"
                        ],
                        "block_filter": [
                            {
                                "tags": "q.any_tag('grass','stone','wood', 'metal')" // Allowed blocks to place the torch at
                            }
                        ]
                    }
                ]
            },
            "spimton:dungeon_torch": {
                "toggle_state": "spimton:lit",
                "particles": [
                    "minecraft:basic_smoke_particle",
                    "spimton:grand_flame"
                ]
            },
            "tag:minecraft:is_pickaxe_item_destructible": {},
            "minecraft:collision_box": {
                "origin": [
                    -1.75,
                    0,
                    -1.75
                ],
                "size": [
                    3.5,
                    10,
                    3.5
                ]
            },
            "minecraft:tick": {
                "interval_range": [
                    20,
                    20
                ],
                "looping": true
            },
            "minecraft:destructible_by_mining": { // Hardness
                "seconds_to_destroy": 3
            },
            "minecraft:destructible_by_explosion": { // Blast resistance
                "explosion_resistance": 4
            },
            "spimton:toggle": {
                "block_state": "spimton:lit",
                "enable_sound": "mob.ghast.fireball",
                "disable_sound": "random.fizz"
            },
            "minecraft:light_emission": 14, // Makes the torch emit light
            "minecraft:light_dampening": 0,
            "minecraft:material_instances": {
                "*": {
                    "texture": "overgrown_dungeon_torch", // The texture used for the torch
                    "render_method": "alpha_test"
                }
            }
        }
    }
}